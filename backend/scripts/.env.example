# Ejemplo de variables de entorno para git_sync_planillas.py
# Copia este archivo a .env o exporta las variables en tu shell antes de ejecutar.

# URL del remote (por defecto usa el repo proporcionado por Larry):
GIT_REMOTE=https://github.com/larryjanpierrmurcialozano/proyecto-de-grado.git

# Ruta local donde clonar/actualizar el repo (opcional)
GIT_REPO_DIR=./planillas_repo

# Rama destino
GIT_BRANCH=planillas

# Autor (obligatorio para que aparezca como tuyo en GitHub)
GIT_USER_NAME=Tu Nombre
GIT_USER_EMAIL=tu-email@example.com

# PAT opcional (si usas HTTPS y no SSH)
# GIT_PAT=ghp_xxx
